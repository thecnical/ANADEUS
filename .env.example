# ──────────────────────────────────────────────────
# ANADEUS — Environment Configuration
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# At least ONE provider must be configured for AI features.
# ──────────────────────────────────────────────────

# ─── PRIMARY PROVIDER: Bytez ─────────────────────
# Sign up at https://bytez.com
BYTEZ_API_KEY=
BYTEZ_BASE_URL=https://api.bytez.com/v1
BYTEZ_MODEL=

# ─── FALLBACK PROVIDER: OpenRouter ───────────────
# Sign up at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── OPTIONAL ────────────────────────────────────
# OPENROUTER_HTTP_REFERER=https://anadeus.local
# ANADEUS_WORKSPACE_ROOT=./workspace
